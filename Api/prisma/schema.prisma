// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shops     Shop[]
}

model Shop {
  id          String            @id @default(cuid())
  name        String
  ownerId     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  customers   Customer[]
  categories  Category[]
  products    Product[]
  inventory   InventoryBatch[]
  adjustments StockAdjustment[]
  orders      Order[]
  payments    Payment[]
  expenses    Expense[]
  setting     ShopSetting?

  @@index([ownerId])
}

model ShopSetting {
  id                  String   @id @default(cuid())
  shopId              String   @unique
  productLabel        String   @default("Product")
  option1Label        String   @default("Option 1")
  option2Label        String   @default("Option 2")
  option2Enabled      Boolean  @default(true)
  productListLabel    String   @default("Products")
  option1ValuesLabel  String   @default("Option 1 Values")
  option2ValuesLabel  String   @default("Option 2 Values")
  option1Values       String   @default("[\"Standard\"]")
  option2Values       String   @default("[\"General\"]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  shop                Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  city      String?
  notes     String?
  shopId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([shopId])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  shopId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([shopId, name])
  @@index([shopId])
}

model Product {
  id          String           @id @default(cuid())
  name        String
  description String?
  sku         String?
  price       Int
  cost        Int?
  isActive    Boolean          @default(true)
  shopId      String
  categoryId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  shop        Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category    Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants    ProductVariant[]
  inventory   InventoryBatch[]
  orderItems  OrderItem[]

  @@unique([shopId, sku])
  @@index([shopId])
  @@index([categoryId])
}

model ProductVariant {
  id         String           @id @default(cuid())
  name       String
  sku        String?
  price      Int?
  cost       Int?
  option1    String?
  option2    String?
  option3    String?
  isActive   Boolean          @default(true)
  productId  String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory  InventoryBatch[]
  orderItems OrderItem[]

  @@unique([productId, sku])
  @@index([productId])
}

model InventoryBatch {
  id               String                @id @default(cuid())
  shopId           String
  productId        String
  variantId        String?
  quantity         Int
  reservedQuantity Int                   @default(0)
  unitCost         Int
  receivedAt       DateTime              @default(now())
  note             String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  shop             Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product          Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant          ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)
  adjustments      StockAdjustment[]
  allocations      OrderItemAllocation[]

  @@index([shopId])
  @@index([productId])
  @@index([variantId])
}

model StockAdjustment {
  id               String         @id @default(cuid())
  shopId           String
  inventoryBatchId String
  action           String
  quantity         Int
  beforeQuantity   Int
  afterQuantity    Int
  reason           String
  createdAt        DateTime       @default(now())
  shop             Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  inventoryBatch   InventoryBatch @relation(fields: [inventoryBatchId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([inventoryBatchId])
}

model Order {
  id                String      @id @default(cuid())
  shopId            String
  customerId        String?
  orderNumber       String?
  fulfillmentStatus String      @default("reserved")
  paymentStatus     String      @default("unpaid")
  subtotal          Int
  discount          Int         @default(0)
  deliveryFee       Int         @default(0)
  total             Int
  source            String?
  note              String?
  refundId          String?
  cancelledAt       DateTime?
  completedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  shop              Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer          Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  payments          Payment[]

  @@unique([shopId, orderNumber])
  @@index([shopId])
  @@index([customerId])
  @@index([fulfillmentStatus])
  @@index([paymentStatus])
}

model OrderItem {
  id            String                @id @default(cuid())
  orderId       String
  productId     String
  variantId     String?
  productName   String
  variantName   String?
  quantity      Int
  unitPrice     Int
  unitCost      Int
  discount      Int                   @default(0)
  deductionType String                @default("discount")
  lineTotal     Int
  createdAt     DateTime              @default(now())
  order         Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant       ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)
  allocations   OrderItemAllocation[]

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model OrderItemAllocation {
  id               String         @id @default(cuid())
  orderItemId      String
  inventoryBatchId String
  quantity         Int
  unitCost         Int
  createdAt        DateTime       @default(now())
  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  inventoryBatch   InventoryBatch @relation(fields: [inventoryBatchId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([inventoryBatchId])
}

model Payment {
  id                String   @id @default(cuid())
  shopId            String
  orderId           String?
  type              String
  scope             String?
  method            String
  amount            Int
  billNumber        String?
  transactionId     String?
  orderIds          String?
  allocations       String?
  originalPaymentId String?
  reason            String?
  note              String?
  paidAt            DateTime @default(now())
  createdAt         DateTime @default(now())
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order             Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([orderId])
  @@index([billNumber])
  @@index([originalPaymentId])
  @@index([transactionId])
}

model Expense {
  id        String   @id @default(cuid())
  shopId    String
  title     String
  category  String?
  amount    Int
  spentAt   DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([spentAt])
}
